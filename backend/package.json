{
  "name": "zollhof-impact-twin-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend + contract for the Zollhof Impact Digital Twin (twin core + /api/tag).",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "gen:schema": "tsx src/contract/emit-json-schema.ts",
    "test:contract": "tsx src/contract/contract.test.ts",
    "test:prompt": "tsx src/twin/prompt.smoke.ts",
    "test:tag": "tsx src/twin/tagProfile.smoke.ts",
    "test:api": "tsx src/api/api.smoke.ts",
    "test": "npm run typecheck && npm run test:contract && npm run test:prompt && npm run test:tag && npm run test:api"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.113.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vercel/node": "^5.8.26",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
